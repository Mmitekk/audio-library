generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SoundRequest {
  id          String   @id @default(cuid())
  name        String
  email       String?
  description String
  fulfilled   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
